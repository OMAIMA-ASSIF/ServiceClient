<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#FFFCFF"
                android:endColor="#FFFCFF"
                android:angle="180"
                android:type="linear"
                />
            <corners android:radius="12dp"/>
            <padding
                android:left="16dp"
                android:right="12dp"
                android:top="16dp"
                android:bottom="12dp"
                />
        </shape>
    </item>
</selector>